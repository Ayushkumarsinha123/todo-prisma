generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int     @id @default(autoincrement())
  title     String
  description   String?
  done Boolean @default(false)
  authorId  Int
  User      User    @relation(fields: [authorId], references: [id])
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  password  String
  name String
  todos  Todo[]
}
